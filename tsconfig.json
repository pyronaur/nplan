{
	"compilerOptions": {
		"target": "ES2023",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"types": ["node"],
		"lib": ["ES2023"]
	},
	"include": ["*.ts", "tests/**/*.ts"]
}